# =============================================
# AXKA BUILDER - Environment Variables
# Copy file ini ke .env dan sesuaikan isinya
# =============================================

# Server
PORT=3000
NODE_ENV=production

# JWT Secret - WAJIB diganti
JWT_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter

# =============================================
# Admin credentials (default, bisa diubah via app.py)
# Username: AXKA
# Password: Asiafone11
# =============================================

# =============================================
# BUILD APK
# =============================================
LOCAL_BUILD=true
# EXTERNAL_BUILD_API=https://your-build-server.com
# EXTERNAL_BUILD_KEY=your_key

# =============================================
# OPENROUTER API KEYS (7 key, fallback otomatis)
# Daftar di: https://openrouter.ai
# =============================================

# =============================================
# BATAS HARIAN PER USER
# =============================================
LIMIT_FREE=5
LIMIT_PRO=80
# ProMax = unlimited

# AI Limit: Free=10/2jam, Pro=80/2jam, ProMax=unlimited
# (dikonfigurasi otomatis di routes/ai.js)

# Upload size limits (MB)
MAX_APK_SIZE_MB=150
MAX_HTML_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10
